{
    "name": "blacklabs/blacklabs",
    "description": "The Black Labs CLI.",
    "keywords": ["console", "cli", "blacklabs"],
    "homepage": "https://blacklabapps.com",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ChaDonSom/blacklabs/issues",
        "source": "https://github.com/ChaDonSom/blacklabs"
    },
    "authors": [
        {
            "name": "Chase Somero",
            "email": "chadonsom@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "czproject/git-php": "^4.1",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/http": "^12.0",
        "illuminate/log": "^12.0",
        "intonate/tinker-zero": "^1.2",
        "laravel-zero/framework": "^12.0",
        "laravel-zero/phar-updater": "^1.4.2",
        "laravel/pint": "^1.25",
        "laravel/prompts": "^0.3.8",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/termwind": "^2.3.3",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-faker": "^3.0",
        "phpacker/phpacker": "^0.6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/blacklabs"]
}
